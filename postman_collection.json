        "key": "token",
        "value": "{{api_key}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://6nzg6akbjzc99a.api.runpod.ai"
    },
    {
      "key": "api_key",
      "value": "replace-with-a-long-random-token"
