        {
          "name": "Download Model Artifacts",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{ltx_model}}\",\n  \"force\": false,\n  \"local_files_only\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/models/download",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "models",
                "download"
              ]
            }
          }
        },
        {
          "name": "Download LTX FP8 Artifacts",
          "request": {
            "description": "Requires server config OPENAI_MULTI_BACKEND_LTX_REPO_ID=Lightricks/LTX-2.3-fp8.",
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{ltx_model}}\",\n  \"files\": [\n    \"ltx-2.3-22b-distilled-fp8.safetensors\"\n  ],\n  \"force\": false,\n  \"local_files_only\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/models/download",
              "host": [
                "{{base_url}}"
