    {
      "name": "Text",
      "item": [
        {
          "name": "Chat Completion",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{chat_model}}\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a concise assistant.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Write a short production deployment checklist.\"\n    }\n  ],\n  \"temperature\": 0.7,\n  \"top_p\": 0.95,\n  \"max_tokens\": 256,\n  \"stream\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/chat/completions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "chat",
                "completions"
              ]
            }
          }
        },
