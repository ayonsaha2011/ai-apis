OPENAI_MULTI_BACKEND_ENVIRONMENT=production
# OPENAI_MULTI_BACKEND_API_KEYS=replace-with-a-long-random-token  # omit to disable app-level auth (e.g. RunPod handles it)
OPENAI_MULTI_BACKEND_HOST=0.0.0.0
OPENAI_MULTI_BACKEND_PORT=8000
OPENAI_MULTI_BACKEND_LOG_LEVEL=INFO
OPENAI_MULTI_BACKEND_MODEL_CACHE_DIR=.model-cache
OPENAI_MULTI_BACKEND_OUTPUT_DIR=.generated
OPENAI_MULTI_BACKEND_DEFAULT_DEVICE=auto
OPENAI_MULTI_BACKEND_TORCH_DTYPE=auto
OPENAI_MULTI_BACKEND_ENABLED_MODELS=Lightricks/LTX-2.3,dx8152/Flux2-Klein-9B-Consistency,llmfan46/gemma-4-26B-A4B-it-ultra-uncensored-heretic,nvidia/parakeet-tdt-0.6b-v3,openai/whisper-large-v3-turbo,Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice,coqui/XTTS-v2
OPENAI_MULTI_BACKEND_HF_TOKEN=
OPENAI_MULTI_BACKEND_TRUST_REMOTE_CODE_MODELS=
OPENAI_MULTI_BACKEND_MAX_CONCURRENT_MODEL_LOADS=1
OPENAI_MULTI_BACKEND_MAX_CONCURRENT_INFERENCES_PER_MODEL=1
OPENAI_MULTI_BACKEND_MAX_UPLOAD_BYTES=104857600
OPENAI_MULTI_BACKEND_REQUEST_TIMEOUT_SECONDS=900
OPENAI_MULTI_BACKEND_EXTERNAL_BASE_URL=
OPENAI_MULTI_BACKEND_VOICE_REFERENCE_DIR=
OPENAI_MULTI_BACKEND_VOICE_REFERENCE_URL_ALLOWED_HOSTS=
OPENAI_MULTI_BACKEND_LTX_REPO_ID=Lightricks/LTX-2.3
OPENAI_MULTI_BACKEND_LTX_PIPELINE_MODULE=ltx_pipelines.distilled
OPENAI_MULTI_BACKEND_LTX_CHECKPOINT_PATH=
OPENAI_MULTI_BACKEND_LTX_CHECKPOINT_FILENAME=ltx-2.3-22b-distilled-1.1.safetensors
OPENAI_MULTI_BACKEND_LTX_SPATIAL_UPSAMPLER_PATH=
OPENAI_MULTI_BACKEND_LTX_SPATIAL_UPSAMPLER_FILENAME=ltx-2.3-spatial-upscaler-x2-1.1.safetensors
OPENAI_MULTI_BACKEND_LTX_GEMMA_ROOT=
OPENAI_MULTI_BACKEND_LTX_DISTILLED_LORA_PATH=
